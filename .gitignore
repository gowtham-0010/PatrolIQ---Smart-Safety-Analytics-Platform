# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environment
patrol/
venv/
env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# -------------------------------------------------------------------
# Data files
# -------------------------------------------------------------------
# Ignore raw/full datasets (they can be very large)
data/
data/*.csv

# -------------------------------------------------------------------
# Artifacts for Streamlit
# -------------------------------------------------------------------
# Ignore everything in artifacts by default...
artifacts/*

# ...but keep the small, preprocessed samples used by the app
!artifacts/geo_clustered_sample.csv
!artifacts/temporal_clustered_sample.csv
!artifacts/pca_tsne_sample.csv
!artifacts/processed_crime_data.csv   # main processed dataset for home page (rename if different)

# If you have more small sample CSVs that Streamlit needs, un-ignore them the same way:
# !artifacts/another_sample.csv

# -------------------------------------------------------------------
# ML models (optional to track; usually small enough)
# -------------------------------------------------------------------
# If you want to KEEP models in Git, comment these out.
*.joblib
*.pkl

# OS files
.DS_Store
Thumbs.db

# VS Code
.vscode/

# Streamlit cache
.streamlit/

# MLflow tracking directory (can get large)
mlflow_tracking/